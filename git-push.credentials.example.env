# Скопируйте в git-push.credentials.env и подставьте свои значения:
#   cp git-push.credentials.example.env git-push.credentials.env
#
# GitHub для HTTPS больше не принимает «пароль от аккаунта».
# В GITHUB_TOKEN укажите Personal Access Token (classic или fine-grained с доступом к repo).
# Создать: https://github.com/settings/tokens
#
# Пробелы вокруг = не ставьте. Значение токена в кавычки оборачивайте только если в нём есть пробелы.

GITHUB_USERNAME=your_github_login
GITHUB_TOKEN=ghp_paste_token_here
