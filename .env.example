# Локальный запуск без Docker (опционально): скопируйте в .env или экспортируйте в shell.
# Для Docker используйте admin-credentials.env — см. README.

# Подключение к MySQL (если не задан DATABASE_URL)
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=phishing_literacy

# Или одной строкой:
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/phishing_literacy

# Админ для seed/start (дублирует admin-credentials.env при ручном запуске node)
# ADMIN_LOGIN=pl_admin
# ADMIN_PASSWORD=your-secure-password

# PORT=3000
