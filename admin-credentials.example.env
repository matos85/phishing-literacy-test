# Учётная запись администратора (скопируйте в admin-credentials.env и задайте свои значения).
# В репозитории хранится только этот пример; реальный файл admin-credentials.env в .gitignore.
#
# Windows (PowerShell): Copy-Item admin-credentials.example.env admin-credentials.env
# Linux/macOS: cp admin-credentials.example.env admin-credentials.env

ADMIN_LOGIN=pl_admin
ADMIN_PASSWORD=Cpl_admin

# Уведомления в MAX (опционально). Если MAX_TOKEN или MAX_GROUP пусты — запросы не отправляются.
# Только UUID и IP; визиты с пути /admin не отправляются.
# Отправка при POST /api/visits (не с /admin). Повтор для того же UUID в одном процессе не дублируется.
# MAX_SEND_URL=https://lk.dtel.ru/max/send
# MAX_TOKEN=
# MAX_GROUP=
